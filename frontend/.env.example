# Frontend Environment Variables (Optional - all features work without these)

# API Configuration (for future integration)
NEXT_PUBLIC_API_URL=http://localhost:3001

# Network Configuration
NEXT_PUBLIC_ORIGIN_CHAIN=1301
NEXT_PUBLIC_REACTIVE_CHAIN=5318007

# Block Explorers
NEXT_PUBLIC_ETHERSCAN_API_KEY=
NEXT_PUBLIC_REACTSCAN_API_KEY=

# RPC Endpoints (for future live data)
NEXT_PUBLIC_UNICHAIN_RPC=https://sepolia.unichain.org
NEXT_PUBLIC_REACTIVE_RPC=https://lasna-rpc.rnk.dev/

# Contract Addresses (update with your deployed addresses)
NEXT_PUBLIC_SWAP_EMITTER=
NEXT_PUBLIC_BRAIN_ADDRESS=
NEXT_PUBLIC_HOOK_ADDRESS=
NEXT_PUBLIC_REACTIVE_PROXY=0x0000000000000000000000000000000000fffFfF

# Feature Flags
NEXT_PUBLIC_SHOW_MOCK_DATA=true
NEXT_PUBLIC_ENABLE_LIVE_MODE=false
NEXT_PUBLIC_DEBUG_MODE=false
